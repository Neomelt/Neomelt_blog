---
import { normalizeWalinePath } from "../utils/waline";
import { getDefaultUiText } from "../i18n/ui";
import {
  walineLoaderScript,
  WALINE_CLIENT_SCRIPT_URLS,
} from "../utils/waline-loader";

interface Props {
  path?: string;
}

const { path = Astro.url.pathname } = Astro.props;
const walinePath = normalizeWalinePath(path);
const serverURL = (import.meta.env.PUBLIC_WALINE_SERVER_URL ?? "").trim();
const walineEmojiUrls = [
  "https://cdn.jsdelivr.net/npm/@waline/emojis@1.4.0/bmoji",
  "https://cdn.jsdelivr.net/npm/@waline/emojis@1.4.0/bilibili",
];
const commentsFallbacks = {
  loadFailedPrefix: getDefaultUiText("comments.loadFailedPrefix"),
  noServerPrefix: getDefaultUiText("comments.noServerPrefix"),
};
const commentsScript = serverURL
  ? `(() => {
	const serverURL = ${JSON.stringify(serverURL)};
	const walinePath = ${JSON.stringify(walinePath)};
	const walineEmojiUrls = ${JSON.stringify(walineEmojiUrls)};
	${walineLoaderScript(WALINE_CLIENT_SCRIPT_URLS)}

	const showFallback = () => {
		const fallback = document.getElementById("waline-fallback");
		if (fallback) fallback.style.display = "block";
	};

	const initWaline = () => {
		window.__walineLoadClient()
			.then((waline) => {
				if (!document.querySelector("#waline")) return;
				waline.init({
					el: "#waline",
					serverURL,
					path: walinePath,
					lang: localStorage.getItem("site-locale") === "en" ? "en-US" : "zh-CN",
					dark: "html.dark",
					emoji: walineEmojiUrls,
					pageview: true,
					comment: true,
					meta: ["nick", "mail", "link"],
					requiredMeta: ["nick", "mail"],
				});
			})
			.catch((error) => {
				console.error("[Waline] Failed to initialize comment widget:", error);
				showFallback();
			});
	};

	// Defer the client off the critical path, but load on idle (not on scroll)
	// so the widget's pageview:true increment still fires on every visit — even
	// when the reader never scrolls down to the comments section.
	if (!document.getElementById("waline")) return;
	if ("requestIdleCallback" in window) {
		requestIdleCallback(initWaline, { timeout: 3000 });
	} else {
		setTimeout(initWaline, 1200);
	}
})();`
  : "";
---

<link rel="stylesheet" href="/vendor/waline.css" />

<div class="comments-wrapper">
  {
    serverURL ? (
      <>
        <div id="waline" />
        <div
          id="waline-fallback"
          class="comments-config-tip"
          style="display: none;"
        >
          {commentsFallbacks.loadFailedPrefix}{" "}
          <a href={"https://www.neomelt.cloud" + walinePath}>
            www.neomelt.cloud
          </a>
          。
        </div>
      </>
    ) : (
      <div class="comments-config-tip">
        {commentsFallbacks.noServerPrefix} <code>PUBLIC_WALINE_SERVER_URL</code>
        。
      </div>
    )
  }
</div>

{serverURL && <script is:inline set:html={commentsScript} />}

<style>
  .comments-wrapper {
    width: 100%;
    max-width: 1000px;
    margin: 4rem auto 0;
    padding: 2rem clamp(0.85rem, 3vw, 2em) 0;
    border-top: 1px solid var(--border);
    box-sizing: border-box;
  }

  .comments-config-tip {
    padding: 0.9rem 1rem;
    border: 1px dashed var(--border);
    border-radius: 8px;
    background: var(--bg-code);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .comments-config-tip code {
    color: var(--text);
    font-family: var(--font-mono);
  }

  :global(.wl-editor),
  :global(.wl-panel),
  :global(.wl-card),
  :global(.wl-empty) {
    background: var(--bg-card);
    border-color: var(--border);
  }

  :global(.wl-textarea),
  :global(.wl-input),
  :global(.wl-count) {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .comments-wrapper {
      margin-top: 3rem;
      padding-top: 1.5rem;
    }
  }
</style>
