---
import {
  walineLoaderScript,
  WALINE_CLIENT_SCRIPT_URLS,
} from "../utils/waline-loader";

const serverURL = (import.meta.env.PUBLIC_WALINE_SERVER_URL ?? "").trim();
const walineCounterScript = serverURL
  ? `(() => {
	const serverURL = ${JSON.stringify(serverURL)};
	${walineLoaderScript(WALINE_CLIENT_SCRIPT_URLS)}

	const initWalineCounter = async () => {
		const hasPageviewCounter = Boolean(
			document.querySelector(".waline-pageview-count"),
		);
		const hasCommentCounter = Boolean(
			document.querySelector(".waline-comment-count"),
		);

		if (!hasPageviewCounter && !hasCommentCounter) return;

		const hasCommentWidget = Boolean(document.querySelector("#waline"));
		const updateTarget = document.querySelector(
			".waline-pageview-update[data-path]",
		);
		const waline = await window.__walineLoadClient();
		const tasks = [];

		if (hasPageviewCounter) {
			tasks.push(
				waline.pageviewCount({
					serverURL,
					update: false,
				}),
			);
		}

		if (hasCommentCounter) {
			tasks.push(
				waline.commentCount({
					serverURL,
				}),
			);
		}

		if (updateTarget && !hasCommentWidget) {
			const updatePath = updateTarget.getAttribute("data-path");
			if (updatePath) {
				tasks.push(
					waline.pageviewCount({
						serverURL,
						path: updatePath,
						update: true,
					}),
				);
			}
		}

		await Promise.all(tasks);
	};

	// Defer the 343KB client to idle time so counters never block first paint.
	const start = () =>
		initWalineCounter().catch((error) => {
			console.error("[WalineCounter] Failed to load counters:", error);
		});

	if ("requestIdleCallback" in window) {
		requestIdleCallback(start, { timeout: 3000 });
	} else {
		setTimeout(start, 1200);
	}
})();`
  : "";
---

{serverURL && <script is:inline set:html={walineCounterScript} />}
